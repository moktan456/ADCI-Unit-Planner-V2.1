rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (Firebase Auth UID)
    // Fields:
    //   - uid: string (required) - User ID
    //   - email: string (required) - User email
    //   - role: string (required) - 'admin' or 'viewer'
    //
    // Collection: workspaces
    // Document ID: workspaceId
    // Fields:
    //   - rawStudents: list (required) - Array of student profiles
    //   - offeredUnits: list (required) - Array of string unit codes
    //   - timetable: map (required) - Timetable configuration
    //   - exportedAt: string (optional) - ISO Timestamp
    //   - version: string (optional) - Version string
    //   - updatedBy: string (optional) - UID of last updater
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "websiteadci@gmail.com" && request.auth.token.email_verified == true) ||
         (request.auth.token.email == "admin@adci.edu")); // Default admins
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'viewer'];
    }

    function isValidWorkspace(data) {
      return data.keys().hasAll(['rawStudents', 'offeredUnits', 'timetable']) &&
             data.rawStudents is list &&
             data.offeredUnits is list &&
             data.timetable is map;
    }

    // ===============================================================
    // Routes
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.role == 'viewer'; // Users can self-register as viewers
      allow update: if isAdmin(); // Only admins can change roles
    }

    match /workspaces/{workspaceId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin(); // Only admins can modify the planner data
    }
  }
}
